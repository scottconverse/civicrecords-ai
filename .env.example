# Database
DATABASE_URL=postgresql+asyncpg://civicrecords:civicrecords@postgres:5432/civicrecords

# Auth
# REQUIRED: Secret files are mounted into containers via Docker Compose secrets.
# The app refuses to start without readable *_FILE paths.
JWT_SECRET_FILE=/run/secrets/jwt_secret
FIRST_ADMIN_EMAIL=admin@example.gov
FIRST_ADMIN_PASSWORD_FILE=/run/secrets/first_admin_password

# Local secret source files used by docker-compose.yml. install.sh/install.ps1
# create these files with restrictive permissions under ./data/secrets.
CIVICRECORDS_SECRET_DIR=./data/secrets

# Ollama
OLLAMA_BASE_URL=http://ollama:11434

# Redis
REDIS_URL=redis://redis:6379/0

# Audit
AUDIT_RETENTION_DAYS=1095

# Connector SSRF allowlist (T2C). Comma-separated hostnames or IPs that are
# allowed to bypass the loopback / RFC1918 / link-local / localhost block.
# Empty by default. No wildcard support, no "disable" flag — list exact hosts only.
# Example for an on-prem internal API:
#   CONNECTOR_HOST_ALLOWLIST=internal-api.corp,10.20.30.40
CONNECTOR_HOST_ALLOWLIST=

# Portal mode (T5D, locked B4=(b) minimal public surface).
# Controls whether this deployment exposes a public-facing surface.
#   private (default): staff-only. /auth/register is NOT mounted (returns 404).
#                      No public routes. UserRole.PUBLIC is not assignable via
#                      self-registration. Login screen is the only externally
#                      reachable page.
#   public:            Exposes the minimal public surface — public landing
#                      page, resident-registration (creates UserRole.PUBLIC),
#                      and an AUTHENTICATED records-request submission form
#                      for signed-in public users. Anonymous walk-up
#                      submission is NOT supported (per Scott Option A
#                      2026-04-22); residents must register and sign in first.
# Values are normalized case-insensitively; any value other than "public" or
# "private" raises at startup. Operators choose this at install time via the
# Windows installer or install.ps1/install.sh prompt.
PORTAL_MODE=private

# At-rest encryption key for data_sources.connection_config (T6 / ENG-001).
# REQUIRED: generate a real Fernet key before starting the app.
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# The output is 44 URL-safe base64 characters encoding a 32-byte key.
# The install scripts will generate one for you on a fresh install.
#
# *** BACK THIS KEY UP SEPARATELY FROM YOUR DATABASE. ***
# If you lose the key, every saved data-source `connection_config` becomes
# unreadable — every connector (file_system, rest_api, odbc, manual_drop,
# ...) will fail on the next ingestion run. Treat this value like the
# JWT secret: back it up in a password manager / secrets vault, not in
# the same place as your DB backups.
#
# The app will refuse to start if this is left at the placeholder value.
# Rotation: not supported by a single-key setup (by design — Scott-locked
# single-key posture 2026-04-23). A future slice can add MultiFernet-style
# rotation under the same env var name without a schema change.
ENCRYPTION_KEY=CHANGE-ME-generate-with-fernet-generate-key

# Database
DATABASE_URL=postgresql+asyncpg://civicrecords:civicrecords@postgres:5432/civicrecords

# Auth
# REQUIRED: Generate a real secret before starting the app. Min 32 chars.
#   openssl rand -hex 32
JWT_SECRET=CHANGE-ME-generate-with-openssl-rand-hex-32
FIRST_ADMIN_EMAIL=admin@example.gov
# REQUIRED: Set a strong password (min 12 chars, not in the common blocklist).
# The install scripts will generate one for you on a fresh install. The app
# will refuse to start if this is left at the placeholder value.
#   Generate one manually: openssl rand -base64 24
FIRST_ADMIN_PASSWORD=CHANGE-ME-on-first-login

# Ollama
OLLAMA_BASE_URL=http://ollama:11434

# Redis
REDIS_URL=redis://redis:6379/0

# Audit
AUDIT_RETENTION_DAYS=1095

# Connector SSRF allowlist (T2C). Comma-separated hostnames or IPs that are
# allowed to bypass the loopback / RFC1918 / link-local / localhost block.
# Empty by default. No wildcard support, no "disable" flag — list exact hosts only.
# Example for an on-prem internal API:
#   CONNECTOR_HOST_ALLOWLIST=internal-api.corp,10.20.30.40
CONNECTOR_HOST_ALLOWLIST=
